# Supabase (leads and other features — blog no longer uses Supabase)
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Witflow CMS — blog content (see ../cms/docs/SITE_WEBHOOK_SETUP.md)
CMS_API_BASE_URL=https://your-cms-host.com
CMS_SITE_ID=your-client-uuid-from-cms-admin
CMS_API_KEY=your-shared-secret
CMS_WEBHOOK_SECRET=your-shared-secret
CMS_CONTENT_LOCALE=pt

# Site
NEXT_PUBLIC_SITE_URL=https://bizin.pt
